# ═══════════════════════════════════════════════════════════════
# Orderza — Environment Variables
# Copy to .env.local and fill in all values before running.
# NEVER commit .env.local to version control.
# ═══════════════════════════════════════════════════════════════

# ── App ────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Generate each secret with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=           # 64 hex chars — signs session JWTs
TRACKING_SECRET=          # 64 hex chars — signs per-customer tracking JWTs
DB_ENCRYPTION_KEY=        # 64 hex chars — AES-256-GCM key for API secrets in DB

# ── Supabase ───────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...   # Public anon key (safe for browser)
SUPABASE_SERVICE_ROLE_KEY=eyJ...       # Service role key — SERVER ONLY

# ── 36blocks / MSG91 proxy-auth ───────────────────────────────
# The widget (referenceId) authenticates the user, then MSG91 redirects the
# browser to the redirect URL configured in the 36blocks panel:
#   <NEXT_PUBLIC_APP_URL>/authenticate
# It carries the { ip, user, company } payload ENCRYPTED with your key. We
# decrypt it with BLOCKS_AUTH_SECRET. user.id is stored as
# restaurants.auth_user_id (links all restaurant + menu data); company.id as
# restaurants.blocks_company_id.
NEXT_PUBLIC_36BLOCKS_APP_ID=117230c17829386726a457c304f7d8  # widget referenceId (public)
BLOCKS_AUTH_SECRET=secret               # Encryption/decryption key set in 36blocks
DUMMY_AUTH_ENABLED=true                 # Set false when 36blocks is live
NEXT_PUBLIC_DUMMY_AUTH_ENABLED=true     # Client-side flag for login page

# ── Anthropic (menu extraction) ───────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...           # From console.anthropic.com

# ── Stripe (platform subscription) ───────────────────────────
STRIPE_SECRET_KEY=sk_test_...          # From Stripe dashboard
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...        # From Stripe CLI: stripe listen --print-secret
STRIPE_MONTHLY_PRICE_ID=price_...      # AED 149/month product price ID
STRIPE_ANNUAL_PRICE_ID=price_...       # AED 1,490/year product price ID

# ── Meta Cloud API ────────────────────────────────────────────
# NOTE: Per-restaurant Meta tokens are stored encrypted in the DB.
# This platform-level secret is ONLY used to verify incoming Meta webhooks.
META_APP_SECRET=                       # From Meta app settings → App Secret

# ── MSG91 ─────────────────────────────────────────────────────
# NOTE: Per-restaurant MSG91 keys are stored encrypted in the DB.
# This optional platform key is for Orderza system-level notifications.
MSG91_PLATFORM_API_KEY=                # Optional — your own MSG91 authkey
